NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# SQLite and file storage (relative to backend/ when not absolute)
DB_PATH=database/documents.db
UPLOAD_DIR=uploads
DOCUMENTS_DIR=documents

# Optional Python AI service path (relative to project root)
PYTHON_PATH=python/document_ai.py
PYTHON_COMMAND=python

# Change this in production
JWT_SECRET=dev-super-secret-jwt-key-change-in-prod
JWT_EXPIRES_IN=7d
JWT_REMEMBER_EXPIRES=30d

# Frontend URL for reset links
CLIENT_URL=http://localhost:5173
